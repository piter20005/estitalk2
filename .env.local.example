# Sanity — publiczne (widoczne w kodzie klienta, bezpieczne do commitowania w .env.local)
NEXT_PUBLIC_SANITY_PROJECT_ID=0hc5qcym
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-01

# Read token — używany server-side (ISR/SSG fetch).
# Nadaj w Sanity dashboard rolę "Viewer", dodaj jako Netlify env var.
SANITY_API_READ_TOKEN=

# Write token — TYLKO dla skryptu scripts/sync-rss-to-sanity.js.
# Dodaj jako GitHub Secret (SANITY_WRITE_TOKEN), NIE dodawaj do Netlify.
SANITY_WRITE_TOKEN=

# Stripe — sekretny klucz API (sk_live_... lub sk_test_...).
# Używany przez /api/doctors/grant do weryfikacji sesji Checkout.
# Dodaj jako Netlify env var (NIE jako NEXT_PUBLIC).
STRIPE_SECRET_KEY=

# Sekret HMAC do podpisywania cookie dostępu „For Doctors".
# Wygeneruj losowo: `openssl rand -base64 32`
# Dodaj jako Netlify env var. Po zmianie tej wartości wszystkie istniejące
# cookie tracą ważność (kupujący muszą przejść proces ponownie).
DOCTORS_ACCESS_SECRET=
